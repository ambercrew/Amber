{
	"name": "brainy",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"lint": "eslint .",
		"test": "vitest",
		"uitest": "vitest --ui",
		"coverage": "vitest run --coverage",
		"format": "prettier . --write",
		"prepare": "husky && npm run install-rust-tools",
		"install-rust-tools": "(rustup component add rustfmt clippy) || echo '⚠️ Warning: Rust tools installation failed. Please install manually: rustfmt, and clippy'",
		"devtools": "react-devtools",
		"update-npm": "ncu --upgrade --cooldown 14",
		"tauri:windows:build": "set STORE_BUILD=1 && tauri-windows-bundle build"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css,md,html}": "prettier --write",
		"*.rs": "cargo fmt --manifest-path ./src-tauri/Cargo.toml --"
	},
	"dependencies": {
		"@fontsource-variable/noto-sans": "^5.2.10",
		"@lexical/code-shiki": "^0.46.0",
		"@lexical/html": "0.46.0",
		"@lexical/link": "0.46.0",
		"@lexical/list": "0.46.0",
		"@lexical/mark": "0.46.0",
		"@lexical/react": "0.46.0",
		"@mantine/core": "^9.4.1",
		"@mantine/dropzone": "^9.4.1",
		"@mantine/form": "^9.4.1",
		"@mantine/hooks": "^9.4.1",
		"@mantine/modals": "^9.4.1",
		"@mantine/spotlight": "^9.4.1",
		"@mdi/js": "7.4.47",
		"@mdi/react": "1.6.1",
		"@mozilla/readability": "^0.6.0",
		"@phosphor-icons/react": "^2.1.10",
		"@reduxjs/toolkit": "2.12.0",
		"@tauri-apps/api": "2.11.1",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "2.7.1",
		"@tauri-apps/plugin-http": "^2.5.9",
		"@tauri-apps/plugin-log": "^2.8.0",
		"@tauri-apps/plugin-opener": "2.5.4",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-process": "2.3.1",
		"@tauri-apps/plugin-updater": "2.10.1",
		"@tauri-apps/plugin-window-state": "2.4.1",
		"dompurify": "^3.4.11",
		"katex": "^0.17.0",
		"lexical": "0.46.0",
		"mupdf": "^1.28.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-redux": "9.3.0",
		"react-router": "8.1.0",
		"shiki": "^4.3.0"
	},
	"devDependencies": {
		"@choochmeque/tauri-windows-bundle": "^0.1.28",
		"@eslint/js": "^9.39.4",
		"@lexical/eslint-plugin": "^0.46.0",
		"@rolldown/plugin-babel": "^0.2.3",
		"@tauri-apps/cli": "2.11.4",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/eslint-config-prettier": "6.11.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@types/react-redux": "7.1.34",
		"@typescript-eslint/parser": "8.62.1",
		"@vitejs/plugin-react": "6.0.3",
		"@vitest/coverage-v8": "4.1.9",
		"@vitest/ui": "4.1.9",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^9.9.1",
		"eslint-config-mantine": "^4.0.3",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.17.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react-refresh": "0.5.3",
		"globals": "17.7.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.8",
		"npm-check-updates": "^22.2.9",
		"postcss": "^8.5.16",
		"postcss-preset-mantine": "^1.18.0",
		"postcss-simple-vars": "^7.0.1",
		"prettier": "3.9.4",
		"react-devtools": "^7.0.1",
		"typescript": "6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "8.1.2",
		"vitest": "^4.1.9"
	}
}
