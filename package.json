{
	"name": "brainy",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"lint": "eslint .",
		"test": "vitest",
		"uitest": "vitest --ui",
		"coverage": "vitest run --coverage",
		"format": "prettier . --write",
		"prepare": "husky && npm run install-rust-tools",
		"install-rust-tools": "(rustup component add rustfmt clippy && cargo install sqlx-cli) || echo '⚠️ Warning: Rust tools installation failed. Please install manually: rustfmt, clippy, and sqlx-cli'",
		"devtools": "react-devtools",
		"update-npm": "ncu --upgrade --cooldown 14"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css,md,html}": "prettier --write",
		"*.rs": "cargo fmt --manifest-path ./src-tauri/Cargo.toml --"
	},
	"dependencies": {
		"@dnd-kit/collision": "^0.4.0",
		"@dnd-kit/dom": "^0.4.0",
		"@dnd-kit/react": "^0.4.0",
		"@fontsource-variable/noto-sans": "^5.2.10",
		"@lexical/html": "0.44.0",
		"@lexical/list": "0.44.0",
		"@lexical/mark": "0.44.0",
		"@lexical/react": "0.44.0",
		"@mdi/js": "7.4.47",
		"@mdi/react": "1.6.1",
		"@reduxjs/toolkit": "2.11.2",
		"@tauri-apps/api": "2.11.0",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "2.7.0",
		"@tauri-apps/plugin-opener": "2.5.3",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-process": "2.3.1",
		"@tauri-apps/plugin-updater": "2.10.1",
		"@tauri-apps/plugin-window-state": "2.4.1",
		"focus-trap-react": "^12.0.1",
		"lexical": "0.44.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-markdown": "^10.1.0",
		"react-redux": "9.2.0",
		"react-router": "7.14.2",
		"react-tooltip": "6.0.0",
		"ts-fsrs": "5.3.2"
	},
	"devDependencies": {
		"@eslint/js": "9.39.4",
		"@lexical/eslint-plugin": "^0.44.0",
		"@rolldown/plugin-babel": "^0.2.3",
		"@tauri-apps/cli": "2.11.0",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/eslint-config-prettier": "6.11.3",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@types/react-redux": "7.1.34",
		"@typescript-eslint/parser": "8.59.1",
		"@vitejs/plugin-react": "6.0.1",
		"@vitest/coverage-v8": "4.1.5",
		"@vitest/ui": "4.1.5",
		"eslint": "9.39.4",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react-refresh": "0.5.2",
		"globals": "17.6.0",
		"happy-dom": "^20.9.0",
		"history": "^5.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"npm-check-updates": "^22.1.0",
		"prettier": "3.8.3",
		"react-devtools": "^7.0.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.1",
		"vite": "8.0.10",
		"vitest": "4.1.5"
	}
}
