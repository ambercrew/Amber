{
	"name": "brainy",
	"private": true,
	"version": "1.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"lint": "eslint .",
		"test": "vitest",
		"uitest": "vitest --ui",
		"coverage": "vitest run --coverage",
		"format": "prettier . --write",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css,md,html}": "prettier --write",
		"*.rs": "cargo fmt --manifest-path ./src-tauri/Cargo.toml --"
	},
