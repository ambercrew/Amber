{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Brainy Learn",
    "version": "1.10.1",
    "identifier": "app.brainylearn",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Brainy",
                "width": 1200,
                "height": 1000,
                "dragDropEnabled": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2ODNEQzdDRjc3QTA2NTQKUldSVUJucjNmTnlESnZ3YzJ6aDNNWlptRmExQ3o1L2tmMnM3ZzR3R0xyczAwMHJPQW50RVoyZ0QK",
            "endpoints": [
                "https://github.com/brainylearn/brainy-app/releases/download/latest/latest.json"
            ]
        }
    },
    "bundle": {
        "createUpdaterArtifacts": true,
        "active": true,
        "targets": "all",
        "shortDescription": "Open-source, AI-integrated learning app built around spaced repetition",
        "icon": [
            "icons/32x32.png",
            "icons/128x128@2x.png",
            "icons/128x128.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
